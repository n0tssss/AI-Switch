{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "ai-switch",
  "version": "0.3.0",
  "identifier": "com.ai-switch.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AI-Switch",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": ["https://github.com/n0tssss/ai-switch/releases/latest/download/latest.json"],
      "pubkey": "MCowBQYDK2VwAyEAFDwmVxEk+JzQn/iEmlhoWg8yqCagWQLxMvjhnbKKXY8=",
      "windows": {
        "installMode": "basicUi"
      }
    }
  }
}
